POSTGRES_DB=rqr
POSTGRES_USER=rqr
POSTGRES_PASSWORD=rqr_dev

DATABASE_URL=postgresql://rqr:rqr_dev@localhost:5432/rqr

PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Scoring weights (all layers)
WEIGHT_DYNAMIC=0.30
WEIGHT_ACCELEROMETER=0.20
WEIGHT_TEMPORAL=0.10
ROUTING_ALPHA=1.0

# Phase 2 — Waze LiveMap polling (job queue runs inside PostgreSQL via pg-boss)
# Fetch interval in minutes
WAZE_FETCH_INTERVAL_MINUTES=5
# Bounding box: west,south,east,north
# Default: Greater Kyiv. For all Ukraine use: 22.0,44.0,40.2,52.5
WAZE_UKRAINE_BBOX=30.2,50.2,30.8,50.7

# Phase 4 — Mapbox
# VITE_MAPBOX_TOKEN=your_token_here
